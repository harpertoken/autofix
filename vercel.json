{
  "buildCommand": "npm install --include=optional && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/complete.ts": {
      "maxDuration": 30
    },
    "api/status.ts": {
      "maxDuration": 10
    }
  },
  "env": {
    "VITE_API_BASE_URL": "@api-base-url",
    "VITE_API_TIMEOUT": "30000",
    "VITE_API_MAX_RETRIES": "3",
    "VITE_API_RETRY_DELAY": "1000",
    "LOG_LEVEL": "info",
    "NODE_ENV": "production"
  },
  "regions": ["iad1"]
}
